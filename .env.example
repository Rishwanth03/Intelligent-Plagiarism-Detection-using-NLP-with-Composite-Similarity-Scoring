FLASK_DEBUG=false
FLASK_TESTING=false
VITE_API_BASE_URL=http://localhost:5000
VITE_ADMIN_API_KEY=change-me-local
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=change-me-local
ADMIN_API_KEY=change-me-local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-local
FLASK_SECRET_KEY=dev-secret-change-me
TUNED_PROFILE=pairwise
TUNED_WEIGHTS_PAIRWISE=0.00,0.00,0.00,1.00
TUNED_THRESHOLD_PAIRWISE=0.31
TUNED_WEIGHTS_BBC=0.50,0.30,0.20,0.00
TUNED_THRESHOLD_BBC=0.50

# Rewrite LLM provider selection: none | openai | ollama | anthropic | gemini
REWRITE_AI_PROVIDER=none

# OpenAI
OPENAI_API_KEY=
OPENAI_REWRITE_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_REWRITE_MODEL=llama3.1:8b

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_REWRITE_MODEL=claude-3-5-haiku-latest

# Google Gemini
GEMINI_API_KEY=
GEMINI_REWRITE_MODEL=gemini-1.5-flash
